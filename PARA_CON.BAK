#include<stdio.h>
#include<conio.h>
#include<iostream.h>
class distance
{	private:
		int feet;
		float inch;
	public:
		distance(int i,float f)
		{
		feet=i;
		inch=f;
		}
		void display()
		{
		cout<<"feet="<<feet<<endl;
		cout<<"inch="<<inch<<endl;
		}

};
void main()
{
	distance d1(11,12.5);
	clrscr();
	d1.display();
	getch();

}


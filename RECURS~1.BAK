#include<iostream>  
#include<stdio.h>
#include<conio.h>
void main()
{
clrscr();    
int factorial(int);  
int fact,value;  

cout<<"Enter any number: ";  
cin>>value;  

fact=factorial(value);  

cout<<"Factorial of a number is: "<<fact<<endl;  
getch();  
}  
int factorial(int n)  
{  
if(n<0)  
return(-1); /*Wrong value*/    
if(n==0)  
return(1);  /*Terminating condition*/  
else  
{  
return(n*factorial(n-1));      
}  
}
 